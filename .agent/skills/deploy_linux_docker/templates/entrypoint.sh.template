#!/bin/sh

# Esperar a que la DB responda
echo "Esperando a que la base de datos ($DB_HOST) esté lista..."
MAX_RETRIES=50
COUNT=0

while ! nc -z $DB_HOST 3306; do
  COUNT=$((COUNT + 1))
  if [ $COUNT -gt $MAX_RETRIES ]; then
    echo "❌ Error: La base de datos no respondió tras $MAX_RETRIES segundos."
    exit 1
  fi
  echo "⏳ Esperando a la base de datos ($COUNT/$MAX_RETRIES)..."
  sleep 1
done

echo "✅ Base de datos detectada."

# Ejecutar migraciones si existen
if [ -f "./node_modules/.bin/sequelize" ]; then
  echo "Sincronizando esquema..."
  npx sequelize-cli db:migrate || echo "⚠️ Migraciones saltadas o ya aplicadas."
fi

echo "🚀 Iniciando servidor..."
npm start
